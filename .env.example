# =============================================================================
# AI Secretary — Root .env.example
# =============================================================================
# This is the master example. Each app has its own .env.example with the subset
# of variables it needs. zod validation in packages/shared/src/config-loader.ts
# enforces presence + type at boot.
# =============================================================================

# --- Core runtime ---
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# --- Region pin (must be set per deployment) ---
REGION=us                              # us | eu

# --- Database (Postgres 16 + pgvector) ---
DATABASE_URL=postgres://user:pass@localhost:5432/aisecretary

# --- Redis (per region) ---
REDIS_URL=redis://localhost:6379

# --- Storage ---
STORAGE_PROVIDER=s3                    # s3 | azure-blob | gcs | minio
S3_BUCKET=ai-secretary-recordings-us
S3_REGION=us-east-1
S3_ENDPOINT=                           # set when using MinIO; e.g. http://localhost:9000
S3_FORCE_PATH_STYLE=false              # true for MinIO
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Aliases used by @aws-sdk/client-s3 default chain — same values as above.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Auth (Story 1.5a/c/e) ---
JWT_SECRET=change-me-in-production-32-chars-min
JWT_ISSUER=https://us.aisecretary.app
JWT_AUDIENCE=aisecretary-api
ACCESS_TOKEN_TTL_SECONDS=900           # 15 min
REFRESH_TOKEN_TTL_SECONDS=2592000      # 30 days
# Story 1.5c — separate secret for MFA challenge JWTs (5-min TTL).
JWT_MFA_CHALLENGE_SECRET=change-me-in-production-32-chars-min-2
# Story 1.5c — AES-256-GCM key for `users.mfa_secret_encrypted`. 64 hex chars.
# Generate via: openssl rand -hex 32
MFA_SECRET_ENCRYPTION_KEY=change-me-with-64-hex-chars-aes-256-gcm-key

# --- LLM gateway (Story 11 / packages/llm-gateway) ---
LLM_DEFAULT_PROVIDER=anthropic         # anthropic | openai | azure-openai | bedrock | ollama
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                        # ZDR-mode only
OPENAI_ZDR_ORG_ID=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
BEDROCK_REGION=us-east-1               # for HIPAA tenants via Bedrock
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5-v1:0
OLLAMA_BASE_URL=http://localhost:11434

# --- Transcription (Story 2.2) ---
TRANSCRIPTION_DEFAULT_ENGINE=whisper-api  # whisper-api | faster-whisper
WHISPER_API_KEY=                       # falls back to OPENAI_API_KEY when empty
FASTER_WHISPER_URL=http://localhost:9000
TRANSCRIBE_TIMEOUT_MS=30000
TRANSCRIBE_CONCURRENCY=3

# --- Embeddings ---
EMBEDDING_DEFAULT_PROVIDER=openai      # openai | azure-openai | voyage | self-hosted
EMBEDDING_DEFAULT_MODEL=text-embedding-3-small
VOYAGE_API_KEY=

# --- Notifications (Story 1.10) ---
EMAIL_PROVIDER=postmark                # postmark | ses | smtp
POSTMARK_SERVER_TOKEN=
SES_REGION=us-east-1
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EXPO_ACCESS_TOKEN=                     # Expo push notifications

# --- Sharing (Story 8.x) ---
SHARE_APP_BASE_URL=http://localhost:5173

# --- OAuth (Story 1.5b — scaffolded; credentials wire on demand) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:3001

# --- Stripe (Story 13.x) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Calendar (Nylas) ---
NYLAS_API_KEY=
NYLAS_CLIENT_ID=

# --- Zoom (Server-to-Server OAuth, Story 9.1) ---
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET=

# --- Microsoft Teams (Story 9.2) ---
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# --- LMS LTI 1.3 (Story 10.x) ---
LTI_PRIVATE_KEY_PEM=
LTI_PUBLIC_JWK_URL=

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=
SENTRY_DSN=
POSTHOG_API_KEY=

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,https://us.aisecretary.app

# --- Web client (apps/web; Vite-prefixed) ---
VITE_API_URL=http://localhost:3001

# --- Mobile client (apps/mobile; Expo-prefixed) ---
EXPO_PUBLIC_API_URL=http://localhost:3001

# --- Feature flags ---
FEATURE_BOTS_ENABLED=true
FEATURE_LMS_ENABLED=false              # Enable per region as marketplace approval lands

# --- Workers (pg-boss cron tightening) ---
PG_BOSS_CRON_MONITOR_SECONDS=15        # tighten for the 15s recording-watchdog (Story 4.4)
