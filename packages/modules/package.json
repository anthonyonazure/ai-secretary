  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./general": "./src/general.ts",
    "./sales": "./src/sales.ts",
    "./hr": "./src/hr.ts",
    "./education": "./src/education.ts",
    "./medical": "./src/medical.ts",
