{
  "name": "@aisecretary/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schemas/auth": "./src/schemas/auth.ts",
    "./schemas/dsar": "./src/schemas/dsar.ts",
    "./schemas/invites": "./src/schemas/invites.ts",
    "./schemas/meetings": "./src/schemas/meetings.ts",
    "./schemas/module-output": "./src/schemas/module-output.ts",
    "./schemas/recordings": "./src/schemas/recordings.ts",
    "./schemas/shares": "./src/schemas/shares.ts",
    "./schemas/oauth": "./src/schemas/oauth.ts",
