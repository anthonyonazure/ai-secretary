# Base URL for the AI Secretary API. Read by `apps/mobile/lib/auth/api-client.ts`
# at build/runtime (Expo bakes EXPO_PUBLIC_* vars into the bundle).
#
# Local-dev default tracks the apps/api Fastify server. On a device, replace
# `localhost` with your dev machine's LAN IP.
EXPO_PUBLIC_API_URL=http://localhost:3001
