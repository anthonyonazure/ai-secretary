{
  "name": "@aisecretary/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts",
    "./plugins/audit-logger": "./src/plugins/audit-logger.ts",
    "./plugins/consent-check": "./src/plugins/consent-check.ts",
    "./plugins/db": "./src/plugins/db.ts",
    "./plugins/jwt": "./src/plugins/jwt.ts",
    "./plugins/tenant-context": "./src/plugins/tenant-context.ts",
    "./routes/auth": "./src/routes/auth.ts",
    "./routes/auth-repository": "./src/routes/auth-repository.ts",
    "./routes/meetings-repository": "./src/routes/meetings-repository.ts",
    "./routes/action-items-repository": "./src/routes/action-items-repository.ts",
    "./lib/audit-sink-postgres": "./src/lib/audit-sink-postgres.ts",
    "./lib/audit-types": "./src/lib/audit-types.ts",
    "./lib/consent-checker-db": "./src/lib/consent-checker-db.ts",
    "./lib/db": "./src/lib/db.ts",
    "./lib/erasure-cascade": "./src/lib/erasure-cascade.ts",
    "./lib/http-error": "./src/lib/http-error.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src scripts",
