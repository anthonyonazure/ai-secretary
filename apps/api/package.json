  "dependencies": {
    "@aisecretary/auth": "workspace:*",
    "@aisecretary/consent": "workspace:*",
    "@aisecretary/crm": "workspace:*",
    "@aisecretary/db": "workspace:*",
    "@aisecretary/llm-gateway": "workspace:*",
    "@aisecretary/notifications": "workspace:*",
    "@aisecretary/shared": "workspace:*",
    "@aisecretary/storage": "workspace:*",
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/jwt": "^9.0.0",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "ioredis": "^5.4.0",
    "jose": "^5.9.0",
    "pg-boss": "^10.1.0",
    "pino": "^9.0.0",
    "postgres": "^3.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "otplib": "^12.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
